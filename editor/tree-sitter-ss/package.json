{
  "name": "tree-sitter-ss",
  "version": "0.6.0",
  "description": "Tree-sitter grammar for the ss slide language.",
  "main": "grammar.js",
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter generate && tree-sitter test && tree-sitter query queries/highlights.scm test/highlight.ss --quiet && tree-sitter query queries/locals.scm test/highlight.ss --quiet && tree-sitter query queries/folds.scm test/highlight.ss --quiet"
  },
  "keywords": [
    "tree-sitter",
    "ss",
    "slides",
    "presentation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abap34/ss.git",
    "directory": "editor/tree-sitter-ss"
  },
  "bugs": {
    "url": "https://github.com/abap34/ss/issues"
  },
  "homepage": "https://github.com/abap34/ss/tree/main/editor/tree-sitter-ss",
  "license": "Apache-2.0",
  "devDependencies": {
    "tree-sitter-cli": "^0.25.10"
  },
  "tree-sitter": [
    {
      "scope": "source.ss",
      "file-types": [
        "ss"
      ],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm",
      "folds": "queries/folds.scm"
    }
  ]
}
