{
  "name": "ss-language-support",
  "displayName": "ss Language Support",
  "description": "Minimal editor support for ss slide source files.",
  "version": "0.0.1",
  "publisher": "local",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "onLanguage:ss-slide",
    "onCommand:ss.preview.live",
    "onCommand:ss.checkCurrentFile"
  ],
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ss-slide",
        "aliases": ["ss", "ss-slide"],
        "extensions": [".ss"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ss-slide",
        "scopeName": "source.ss",
        "path": "./syntaxes/ss.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ss-slide",
        "path": "./snippets/ss.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "ss.preview.live",
        "title": "ss: Open Live Preview"
      },
      {
        "command": "ss.checkCurrentFile",
        "title": "ss: Check Current File"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ss.preview.live",
          "when": "resourceLangId == ss-slide",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "ss.preview.live"
        },
        {
          "command": "ss.checkCurrentFile"
        }
      ]
    },
    "configuration": {
      "title": "ss",
      "properties": {
        "ss.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Run ss check-file and publish diagnostics while editing."
        },
        "ss.livePreview.debounceMs": {
          "type": "number",
          "default": 900,
          "minimum": 100,
          "description": "Delay before refreshing the ss live preview after edits."
        },
        "ss.livePreview.openMode": {
          "type": "string",
          "default": "vscode",
          "enum": ["vscode", "external"],
          "enumDescriptions": [
            "Open the generated PDF through VS Code's normal document opening command.",
            "Open the generated PDF with the operating system's external PDF application."
          ],
          "description": "How ss live preview opens the generated PDF."
        }
      }
    }
  }
}
