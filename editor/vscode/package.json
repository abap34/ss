{
  "name": "ss-language-support",
  "displayName": "ss-lang for VS Code",
  "description": "Language server powered editor support for ss slide source files.",
  "version": "0.4.3",
  "publisher": "abap34",
  "license": "Apache-2.0",
  "icon": "assets/logo.png",
  "homepage": "https://github.com/abap34/ss#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/abap34/ss.git",
    "directory": "editor/vscode"
  },
  "bugs": {
    "url": "https://github.com/abap34/ss/issues"
  },
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "package": "vsce package",
    "test": "npm run compile"
  },
  "activationEvents": [
    "onLanguage:ss-slide",
    "onCommand:ss.preview.live",
    "onCommand:ss.checkCurrentFile"
  ],
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "ss",
    "slides",
    "presentation",
    "pdf",
    "lsp",
    "language server"
  ],
  "galleryBanner": {
    "color": "#1f2937",
    "theme": "dark"
  },
  "contributes": {
    "languages": [
      {
        "id": "ss-slide",
        "aliases": [
          "ss",
          "ss-slide"
        ],
        "extensions": [
          ".ss"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ss-slide",
        "scopeName": "source.ss",
        "path": "./syntaxes/ss.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ss-slide",
        "path": "./snippets/ss.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "ss.preview.live",
        "title": "ss: Open Live Preview"
      },
      {
        "command": "ss.checkCurrentFile",
        "title": "ss: Check Current File"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ss.preview.live",
          "when": "resourceLangId == ss-slide",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "ss.preview.live"
        },
        {
          "command": "ss.checkCurrentFile"
        }
      ]
    },
    "configuration": {
      "title": "ss",
      "properties": {
        "ss.cli.path": {
          "type": "string",
          "default": "ss",
          "description": "Path to the ss executable used to launch `ss lsp` and render live previews."
        },
        "ss.lsp.trace.server": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "description": "Trace communication with the ss language server."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
