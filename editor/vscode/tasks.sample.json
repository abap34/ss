{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ss: check current file",
      "type": "shell",
      "command": "zig build run -- check ${file}",
      "problemMatcher": {
        "owner": "ss",
        "fileLocation": ["absolute"],
        "pattern": {
          "regexp": "^(ERROR|WARNING):\\s+(.*):(\\d+):(\\d+):\\s+(.*)$",
          "severity": 1,
          "file": 2,
          "line": 3,
          "column": 4,
          "message": 5
        }
      }
    }
  ]
}
