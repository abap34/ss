{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ss: check current file",
      "type": "shell",
      "command": "zig build run -- check-file ${file}",
      "problemMatcher": {
        "owner": "ss",
        "fileLocation": ["absolute"],
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+): error: (.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        }
      }
    }
  ]
}
