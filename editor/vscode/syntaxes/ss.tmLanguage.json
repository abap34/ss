{
  "scopeName": "source.ss",
  "name": "ss",
  "patterns": [
    { "include": "#comments" },
    { "include": "#block-string" },
    { "include": "#triple-string" },
    { "include": "#color-string" },
    { "include": "#double-string" },
    { "include": "#annotations" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#types" },
    { "include": "#function-call" },
    { "include": "#bare-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-semicolon.ss",
          "match": "(?:;;|//|#).*$"
        }
      ]
    },
    "block-string": {
      "patterns": [
        {
          "name": "string.unquoted.block.ss",
          "begin": "<<\\s*$",
          "end": "^\\s*>>\\s*(?:;;.*)?$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.ss" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.ss" }
          }
        }
      ]
    },
    "triple-string": {
      "patterns": [
        {
          "name": "string.quoted.triple.ss",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.ss" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.ss" }
          }
        }
      ]
    },
    "double-string": {
      "patterns": [
        {
          "name": "string.quoted.double.ss",
          "match": "\"(?:\\\\.|[^\"\\\\])*\""
        }
      ]
    },
    "color-string": {
      "patterns": [
        {
          "captures": {
            "0": { "name": "constant.other.color.ss" }
          },
          "match": "c\"(?:\\\\.|[^\"\\\\])*\""
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ss",
          "match": "\\b(?:import|const|document|page|fn|let|return|end|type|extend|protocol|base|implements|roles|property|if|then|else|for|in)\\b"
        },
        {
          "name": "storage.type.ss",
          "match": "\\b(?:document|page|object|selection|metadata|anchor|string|number|bool|boolean|void|Void|constraints)\\b"
        },
        {
          "name": "constant.language.boolean.ss",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "captures": {
            "0": { "name": "storage.modifier.annotation.ss" },
            "1": { "name": "entity.name.function.annotation.ss" }
          },
          "match": "@([A-Za-z_][A-Za-z0-9_]*)"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "captures": {
            "1": { "name": "keyword.control.ss" },
            "2": { "name": "entity.name.type.class.ss" },
            "3": { "name": "keyword.operator.assignment.ss" },
            "4": { "name": "storage.type.ss" }
          },
          "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)\\s*(object)\\b"
        },
        {
          "captures": {
            "1": { "name": "keyword.control.ss" },
            "2": { "name": "entity.name.type.class.ss" }
          },
          "match": "\\b(extend)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b"
        },
        {
          "captures": {
            "1": { "name": "keyword.control.ss" },
            "2": { "name": "entity.name.type.ss" },
            "3": { "name": "keyword.operator.assignment.ss" }
          },
          "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.ss",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ss",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.ss",
          "match": "\\|->|->|\\?\\?|\\+\\+|==|=|\\?|:|\\||~|\\.|,|!|<|>|\\-|\\+|\\*|/"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "captures": {
            "1": { "name": "entity.name.function.ss" },
            "2": { "name": "punctuation.section.group.begin.ss" }
          },
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*!?)\\s*(\\()"
        }
      ]
    },
    "bare-call": {
      "patterns": [
        {
          "captures": {
            "1": { "name": "entity.name.function.ss" }
          },
          "match": "^(\\s*[A-Za-z_][A-Za-z0-9_]*!?)(?=\\s|$)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.ss",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
