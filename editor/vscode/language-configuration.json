{
  "comments": {
    "lineComment": ";;"
  },
  "wordPattern": "\\|->|->|\\?\\?|\\+\\+|==|\\?|[A-Za-z_][A-Za-z0-9_]*|\\d+(?:\\.\\d+)?",
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["<", ">"]
  ],
  "autoClosingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""],
    ["<<", ">>"]
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(page|fn)\\b",
      "end": "^\\s*end\\b"
    }
  }
}
